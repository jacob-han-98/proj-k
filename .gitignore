# Claude Code 로컬 설정 — skills/scripts/settings.json 는 프로젝트 공유 자산이므로 커밋
# settings.local.json 은 머신별 (Claude Code 가 자동 분리)
.claude/*
!.claude/skills/
!.claude/scripts/
!.claude/settings.json
.claude/skills/_archived/

# Cross-Claude Bridge — role/shared_dir 은 머신별이므로 .example 만 commit
.bridge-config.json

# Telegram 봇 상태 (토큰, access.json)
scripts/telegram/state/
.venv/

# agent-sdk-poc 벤치 측정 결과 (재생성 가능, 사이즈 큼)
packages/agent-sdk-poc/scripts/bench_out/

# desktop-app 일회성 진단 산출물 (스크린샷 비교, probe 스크립트 등)
packages/desktop-app/.tmp-*

# Playwright 테스트 산출물 (실패 trace/screenshot)
test-results/
