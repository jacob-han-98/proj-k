{
  "manifest_version": 3,
  "name": "Project K - Confluence Assistant",
  "version": "0.1.0",
  "description": "AI planning assistant for Confluence pages - summarize and suggest edits",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.atlassian.net/*",
    "https://*.amazonaws.com/*",
    "https://api.anthropic.com/*",
    "http://127.0.0.1:8088/*",
    "https://cp.tech2.hybe.im/*",
    "http://127.0.0.1:19876/*",
    "http://172.20.105.147:19876/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/wiki/*"],
      "js": ["lib/storage.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar/*", "icons/*", "debug.html"],
      "matches": ["*://*.atlassian.net/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
