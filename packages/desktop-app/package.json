{
  "name": "projk-desktop",
  "version": "0.1.49",
  "private": true,
  "description": "Project K planner assistant — Windows desktop app",
  "author": {
    "name": "Project K Team",
    "email": "jaekap.han@gmail.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "build:win-portable": "electron-vite build && electron-builder --win portable --config electron-builder.yml",
    "release": "node scripts/release.mjs",
    "serve:feed": "node scripts/serve-feed.mjs",
    "serve:log-collector": "node scripts/log-collector.mjs",
    "serve:dev-bundle": "node scripts/dev-bundle-server.mjs",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "renderer:test-server": "vite --config vite.renderer.config.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:electron": "playwright test --config=playwright.electron.config.ts",
    "test:sidecar": ".venv/bin/python -m pytest tests/sidecar -v",
    "test": "npm run test:unit && npm run test:sidecar && npm run test:e2e",
    "test:all": "npm run test && npm run test:electron"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "chokidar": "^4.0.1",
    "electron-updater": "^6.3.9",
    "sql.js": "^1.13.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
