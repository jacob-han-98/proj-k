{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "./dist-tsc-web",
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/main/tree-core.ts",
    "tests/e2e-renderer/**/*.ts",
    "tests/unit/**/*.ts"
  ],
  "exclude": [
    "tests/unit/threads-db.test.ts",
    "tests/unit/onedrive-sync.test.ts",
    "tests/unit/confluence-copy.test.ts",
    "tests/unit/confluence-apply-match.test.ts"
  ]
}
