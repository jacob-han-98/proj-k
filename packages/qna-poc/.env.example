# qna-poc 환경 변수
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.

# AWS Bedrock 인증
AWS_BEARER_TOKEN_BEDROCK=your-token-here
AWS_REGION=us-east-1

# 모델 설정
LLM_MODEL=claude-sonnet-4-5
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Slack Bot (Socket Mode)
# Slack App 생성: https://api.slack.com/apps
# 1. Socket Mode 활성화 → App-Level Token 생성 (connections:write)
# 2. OAuth & Permissions → Bot Token Scopes: app_mentions:read, chat:write, reactions:read, reactions:write, im:history, im:read
# 3. Event Subscriptions → Subscribe to bot events: app_mention, message.im
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Streamlit URL (Slack 봇에서 "상세 보기" 링크용)
STREAMLIT_URL=https://cp.tech2.hybe.im/proj-k-agent
