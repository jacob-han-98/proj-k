# xlsx-extractor 환경 변수
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.

# AWS Bedrock 인증
AWS_BEARER_TOKEN_BEDROCK=your-token-here
AWS_REGION=us-east-1

# AI 모델 설정 (기본값: claude-opus)
# claude-opus 외 모델 사용 시 WARNING이 출력됩니다.
VISION_MODEL=claude-opus

# 소스 폴더 오버라이드 (콤마 구분, 절대 경로)
# 미설정 시 프로젝트 하위 7_System, 2_Development, 3_Base, 9_MileStone 사용
# Perforce 외부 워크스페이스 경로 등을 지정할 때 사용
# 예: XLSX_SOURCE_DIRS=D:/p4_workspace/7_System,D:/p4_workspace/9_MileStone
#XLSX_SOURCE_DIRS=
