# Perforce 설정
# p4 CLI가 설치되어 있어야 합니다.

# P4 서버 주소
P4PORT=ssl:perforce.company.com:1666

# P4 사용자명
P4USER=your-username

# P4 워크스페이스(클라이언트) 이름
P4CLIENT=your-workspace

# 동기화할 depot 경로 (하위 전체)
P4_DEPOT_PATH=//depot/ProjectK/7_System/...

# 로컬 동기화 대상 경로 (프로젝트 외부 가능)
# 이 경로에 Perforce 파일이 동기화됩니다.
# xlsx-extractor의 XLSX_SOURCE_DIRS와 맞춰야 합니다.
P4_LOCAL_PATH=D:/p4_workspace/ProjectK/7_System
